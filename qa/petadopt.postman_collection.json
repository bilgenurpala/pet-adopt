  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "Register (unique email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"qa_user_{{$timestamp}}\",\n  \"email\": \"{{new_user_email}}\",\n  \"full_name\": \"QA User\",\n  \"password\": \"qapassword1\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('new_user_email', 'qa_' + Date.now() + '@example.com');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const j = pm.response.json();",
                  "pm.test(\"body has id and email\", function () {",
                  "    pm.expect(j).to.have.property(\"id\");",
                  "    pm.expect(j).to.have.property(\"email\");",
                  "});",
                  "pm.environment.set(\"new_user_id\", j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (regular user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
